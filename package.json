{
  "name": "gate-screener",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @gate-screener/api --filter @gate-screener/web dev",
    "dev:web": "pnpm --filter @gate-screener/web dev",
    "dev:api": "pnpm --filter @gate-screener/api dev",
    "vendor:build:gateio-api": "node ./scripts/build-vendored-gateio-api.mjs",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/node": "^24.6.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.4.0",
    "typescript": "^5.9.3"
  }
}
